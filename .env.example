# Reference only. For local Compose use, run scripts/generate-local-env.sh
# instead of copying this file — it generates real random secrets rather
# than reusing whatever ends up in this example.

POSTGRES_DB=nexus_scheduler
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme

REDIS_PASSWORD=changeme

SESSION_SECRET=changeme-32-chars-minimum
API_KEY_ENCRYPTION_KEY=changeme-32-chars-minimum
# Defense-in-depth on top of NetworkPolicy for the internal pdf-service —
# optional; leave blank to keep pdf-service unauthenticated as before.
PDF_SERVICE_SHARED_SECRET=changeme-32-chars-minimum

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Built-in break-glass admin (REQUIREMENTS §4) — this env var is the
# ongoing source of truth for its password, re-synced on every API
# startup, not just a one-time seed.
BOOTSTRAP_ADMIN_EMAIL=admin@nexus-scheduler.local
BOOTSTRAP_ADMIN_PASSWORD=changeme-12-chars-minimum

# Points at the librechat service this same Compose stack runs — see
# docker/librechat/.env.example for its own config.
LIBRECHAT_BASE_URL=http://librechat:3080

# Space-separated models pulled into Ollama at startup. Every model in
# this list must also have a matching entry in docker/litellm/config.yaml.
OLLAMA_PULL_MODELS=gemma3:1b codegemma:2b phi4-mini-reasoning:3.8b

# Claude/Anthropic as LibreChat's provider for local testing (optional
# — leave blank and LibreChat just won't offer it as an endpoint). Get
# a key at https://console.anthropic.com/ — this is a *different* key
# from anything Nexus Scheduler itself stores; it only ever lives in
# the librechat container's environment.
ANTHROPIC_API_KEY=

# Dedicated LiteLLM virtual key used only by the OCR service for optional
# image-description calls. generate-local-env.sh creates a random value
# and litellm-init provisions it with LLM-only permissions.
LITELLM_OCR_KEY=sk-changeme

# Optional image descriptions are off by default. Enabling them also
# requires OCR_VISION_MODEL to name a multimodal model configured in
# docker/litellm/config.yaml and present in OLLAMA_PULL_MODELS. A text-only
# model will be rejected by LiteLLM when it receives image content.
OCR_DESCRIBE_IMAGES=false
OCR_VISION_MODEL=

# Hard ceiling, in seconds, for one OCR request. The service applies the
# lower of this value and the remaining run budget supplied by the worker.
OCR_MAX_PROCESS_SECONDS=900

# Aggregate bytes retained by the OCR service for LibreChat's temporary
# Mistral-compatible upload store (default 256 MiB, minimum 15 MiB). A
# full store rejects new uploads rather than evicting accepted file IDs.
OCR_FILE_STORE_MAX_BYTES=268435456

# Complete user-prompt character ceiling for scheduled runs with OCR
# attachments. 80k is roughly 20k tokens, leaving room in the bundled
# 32k-context model for system/tool context and output.
OCR_EXTRACTED_TEXT_MAX_CHARS=80000
