# Reference only. For local Compose use, run scripts/generate-local-env.sh
# instead of copying this file — it generates real random secrets rather
# than reusing whatever ends up in this example.

POSTGRES_DB=nexus_scheduler
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme

REDIS_PASSWORD=changeme

SESSION_SECRET=changeme-32-chars-minimum
API_KEY_ENCRYPTION_KEY=changeme-32-chars-minimum

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Built-in break-glass admin (REQUIREMENTS §4) — this env var is the
# ongoing source of truth for its password, re-synced on every API
# startup, not just a one-time seed.
BOOTSTRAP_ADMIN_EMAIL=admin@nexus-scheduler.local
BOOTSTRAP_ADMIN_PASSWORD=changeme-12-chars-minimum

# Points at the librechat service this same Compose stack runs — see
# docker/librechat/.env.example for its own config.
LIBRECHAT_BASE_URL=http://librechat:3080
