// Nexus Scheduler data model.
// Mirrors the illustrative ER diagram in ARCHITECTURE.md §4 and the
// functional requirements in REQUIREMENTS.md §2-§8. Expect this schema to
// evolve as implementation proceeds — treat it as scaffolding, not final.

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity, roles, Teams
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  EDITOR
  VIEW
}

enum AuthSource {
  OIDC
  LOCAL
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  givenName    String?
  familyName   String?
  displayName  String?
  authSource   AuthSource
  passwordHash String? // set only for AuthSource.LOCAL (break-glass fallback, REQUIREMENTS §4)
  // Single-use password-set/reset token — hashed at rest (same principle
  // as never storing secrets in plaintext), short-lived. Doubles as the
  // "set your initial password" mechanism for an admin-created local
  // account (passwordHash starts null; the reset flow is how it gets set).
  passwordResetTokenHash  String?
  passwordResetExpiresAt  DateTime?
  role         Role       @default(VIEW)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  teamMemberships   TeamMembership[]
  ownedProjects      Project[]           @relation("ProjectOwner")
  apiKeys            ApiKey[]
  promptVersions     PromptVersion[]
  jobsCreated        Job[]
  schedulesCreated   Schedule[]
  promptFavorites    PromptFavorite[]
  teamsCreated       Team[]

  @@map("users")
}

model Team {
  id           String   @id @default(uuid())
  name         String
  parentTeamId String?
  parentTeam   Team?    @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  subTeams     Team[]   @relation("TeamHierarchy")
  createdAt    DateTime @default(now())
  // Nullable because teams created before ownership existed have no
  // recorded creator — those stay admin-managed-only until an admin
  // designates an owner, rather than guessing one. Always set for teams
  // created from here forward.
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])

  memberships TeamMembership[]
  apiKeys     ApiKey[]

  @@index([parentTeamId])
  @@map("teams")
}

model TeamMembership {
  teamId   String
  userId   String
  team     Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Owners can edit the team (rename/reparent), manage membership, and
  // delete it; plain members can only see it. A team can have more than
  // one owner. Admins bypass this check entirely and can manage any team.
  isOwner  Boolean @default(false)

  @@id([teamId, userId])
  @@map("team_memberships")
}

enum ApiKeyOwnerType {
  USER
  TEAM
}

enum ApiKeyStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// LibreChat API keys — stored encrypted at rest (REQUIREMENTS §4).
// `encryptedKey` holds ciphertext only; the encryption key itself lives
// outside the DB (K8s Secret / env var), never in this table.
model ApiKey {
  id            String          @id @default(uuid())
  ownerType     ApiKeyOwnerType
  ownerUserId   String?
  ownerTeamId   String?
  owningUser    User?           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  owningTeam    Team?           @relation(fields: [ownerTeamId], references: [id], onDelete: Cascade)
  label         String?
  encryptedKey  String
  status        ApiKeyStatus    @default(ACTIVE)
  expiresAt     DateTime?
  createdAt     DateTime        @default(now())

  jobs Job[]

  @@index([ownerUserId])
  @@index([ownerTeamId])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// Classification & Marking (REQUIREMENTS §6)
// ---------------------------------------------------------------------------

model ClassificationLabel {
  id              String   @id @default(uuid())
  text            String
  abbreviation    String?
  badgeBgColor    String
  badgeTextColor  String
  sortOrder       Int      @default(0)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())

  projects Project[]

  @@map("classification_labels")
}

// ---------------------------------------------------------------------------
// Projects, Prompts, Teams sharing (REQUIREMENTS §2.3)
// ---------------------------------------------------------------------------

enum ProjectVisibility {
  PRIVATE
  SHARED
}

model Project {
  id                     String             @id @default(uuid())
  name                   String
  description            String?
  ownerId                String
  owner                  User               @relation("ProjectOwner", fields: [ownerId], references: [id])
  classificationLabelId  String?
  classificationLabel    ClassificationLabel? @relation(fields: [classificationLabelId], references: [id])
  visibility             ProjectVisibility  @default(PRIVATE)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  acls    ProjectAcl[]
  prompts Prompt[]
  jobs    Job[]

  @@index([ownerId])
  @@map("projects")
}

enum GranteeType {
  USER
  TEAM
  ORG
}

enum AccessLevel {
  READ
  EDIT
}

model ProjectAcl {
  id            String      @id @default(uuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  granteeType   GranteeType
  granteeUserId String?
  granteeTeamId String?
  accessLevel   AccessLevel
  createdAt     DateTime    @default(now())

  @@index([projectId])
  @@index([granteeUserId])
  @@index([granteeTeamId])
  @@map("project_acls")
}

model Prompt {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions  PromptVersion[]
  jobs      Job[]
  favorites PromptFavorite[]

  @@index([projectId])
  @@map("prompts")
}

// One row per edit — REQUIREMENTS §2.3 version history.
model PromptVersion {
  id            String   @id @default(uuid())
  promptId      String
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  versionNumber Int
  content       String
  variables     Json     @default("[]") // declared {{variable}} params: name/type/default
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())

  schedules Schedule[]

  @@unique([promptId, versionNumber])
  @@map("prompt_versions")
}

model PromptFavorite {
  userId    String
  promptId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, promptId])
  @@map("prompt_favorites")
}

// ---------------------------------------------------------------------------
// Jobs, Schedules, Runs (REQUIREMENTS §2.1, §2.4)
// ---------------------------------------------------------------------------

enum VersionPinMode {
  PINNED
  LATEST
}

model Job {
  id                    String          @id @default(uuid())
  projectId             String
  project               Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                  String
  promptId              String
  prompt                Prompt          @relation(fields: [promptId], references: [id])
  agentId               String // LibreChat agent ID (§2.1)
  apiKeyId              String
  // Explicit Restrict (was the implicit default) — a Job always needs a
  // real key to run, so silently nulling it out or cascading the Job's
  // own deletion when its key disappears are both worse than just
  // blocking. This intentionally contradicts ApiKey.owningUser's
  // onDelete: Cascade below it in this file; the users.ts DELETE route
  // checks for exactly this combination before attempting the delete,
  // rather than letting the two policies collide as a raw FK violation.
  apiKey                ApiKey          @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)
  timeoutSeconds         Int            @default(600) // default 10m, ceiling enforced in app logic (§2.1)
  maxRetries             Int            @default(2)
  // Email notification to the Job owner on completion/failure, §2.2 —
  // per-job configurable, independent of the admin-allow-listed webhook
  // delivery above. attachPdfToEmail only has any effect if at least one
  // of the notify flags is also set.
  notifyOnSuccess        Boolean         @default(false)
  notifyOnFailure        Boolean         @default(false)
  attachPdfToEmail       Boolean         @default(false)
  createdById            String
  createdBy              User            @relation(fields: [createdById], references: [id])
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  schedules      Schedule[]
  runs           Run[]
  webhookLinks   JobWebhookDestination[]

  @@index([projectId])
  @@index([promptId])
  @@index([apiKeyId])
  @@index([createdById])
  @@map("jobs")
}

enum ScheduleType {
  ONE_TIME
  RECURRING
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model Schedule {
  id                  String         @id @default(uuid())
  jobId               String
  job                 Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type                ScheduleType
  runAt                DateTime? // set when type === ONE_TIME
  intervalConfig       Json? // interval-picker config, not raw cron (§2); set when type === RECURRING
  timezone             String // IANA tz name (§2.4)
  nextFireAt           DateTime?
  paused               Boolean        @default(false)
  approvalStatus       ApprovalStatus @default(DRAFT)
  versionPinMode       VersionPinMode @default(LATEST)
  pinnedPromptVersionId String?
  pinnedPromptVersion   PromptVersion? @relation(fields: [pinnedPromptVersionId], references: [id])
  // Per-schedule overrides of the prompt's declared {{variable}}
  // defaults (REQUIREMENTS §2.3: "filled in when a schedule is created
  // ... and can be edited later"). Record<variableName, value>.
  variableValues        Json?
  createdById           String
  createdBy             User           @relation(fields: [createdById], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  runs Run[]

  // Matches the scheduler's core poll query (packages/worker/src/
  // scheduler.ts: due schedules where paused = false AND
  // nextFireAt <= now) — without this, that query is a full table scan
  // every tick.
  @@index([paused, nextFireAt])
  @@index([jobId])
  @@map("schedules")
}

enum TriggerType {
  SCHEDULED
  MANUAL
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
  SKIPPED
}

model Run {
  id               String      @id @default(uuid())
  jobId            String
  job              Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  scheduleId       String?
  schedule         Schedule?   @relation(fields: [scheduleId], references: [id])
  triggerType      TriggerType
  status           RunStatus   @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?
  promptTokens     Int?
  completionTokens Int?
  computedCost     Decimal?    @db.Decimal(12, 6)
  output           String?
  errorMessage     String?
  createdAt        DateTime    @default(now())

  @@index([jobId])
  @@index([scheduleId])
  @@map("runs")
}

// ---------------------------------------------------------------------------
// Outbound webhooks (REQUIREMENTS §2.2)
// ---------------------------------------------------------------------------

model WebhookDestination {
  id                    String   @id @default(uuid())
  name                  String
  url                   String // admin-entered — this row *is* the allow-list, §2.2/§10
  // Server-generated, AES-256-GCM encrypted at rest (same scheme as
  // ApiKey.encryptedKey). Returned in plaintext exactly once — from the
  // create response and from POST /:id/rotate-secret — so the receiving
  // endpoint's admin can copy it in to verify X-Nexus-Signature (§27);
  // never returned by GET/PATCH afterward.
  encryptedHmacSecret   String
  // Extra headers merged into every outbound delivery (test-send and
  // real run delivery alike) — e.g. a receiver-side auth token. Record
  // <string,string>; Content-Type and X-Nexus-Signature are always
  // fixed by the sender and can't be overridden via this map (enforced
  // both at the zod-schema layer on write and again at delivery time).
  headers               Json?
  // Per-destination event selection (§27) — which terminal Run
  // statuses actually trigger delivery to this destination. All default
  // true, matching the pre-#27 behavior of delivering every terminal
  // state unconditionally.
  notifyOnSuccess       Boolean  @default(true)
  notifyOnFailure       Boolean  @default(true)
  notifyOnCancelled     Boolean  @default(true)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())

  jobLinks JobWebhookDestination[]

  @@map("webhook_destinations")
}

model JobWebhookDestination {
  jobId                String
  webhookDestinationId String
  job                  Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  webhookDestination   WebhookDestination  @relation(fields: [webhookDestinationId], references: [id], onDelete: Cascade)

  @@id([jobId, webhookDestinationId])
  @@map("job_webhook_destinations")
}

// ---------------------------------------------------------------------------
// Cost rates (REQUIREMENTS §8)
// ---------------------------------------------------------------------------

model CostRate {
  id                        String   @id @default(uuid())
  agentId                   String? // null = global default rate
  promptRatePerMillion      Decimal  @db.Decimal(10, 4)
  completionRatePerMillion  Decimal  @db.Decimal(10, 4)
  effectiveFrom             DateTime @default(now())
  createdAt                 DateTime @default(now())

  // Prevents two rows from claiming the same agent's rate as of the
  // same instant, which would make "the effective rate for agent X as
  // of time T" order-dependent/non-deterministic (costCalculator.ts
  // picks whichever row a query happens to return first). Note this
  // constraint's Postgres semantics don't cover two *global-default*
  // (agentId = null) rows landing on the exact same effectiveFrom —
  // NULLs are never considered equal under a unique index — but that
  // collision would require two creates at literally the same
  // microsecond, a far narrower window than the same-agent case this
  // closes.
  @@unique([agentId, effectiveFrom])
  @@index([agentId, effectiveFrom])
  @@map("cost_rates")
}

// ---------------------------------------------------------------------------
// System settings (REQUIREMENTS §5 branding, §6 classification banner)
// ---------------------------------------------------------------------------

// Singleton row (always id=1, enforced in application code, not a real
// autoincrement sequence) — admin-editable branding and the persistent,
// system-wide classification banner. Deliberately separate from
// ClassificationLabel (§6): that's a per-object taxonomy, this is the
// one static banner shown on every page regardless of content.
model AppSettings {
  id                             Int      @id @default(1)
  productName                    String   @default("Nexus Scheduler")
  logoUrl                        String?
  primaryColor                   String   @default("#1565c0")
  // Loud, obviously-wrong defaults on purpose — REQUIREMENTS §6 requires
  // this be explicitly configured; a plausible-looking default (e.g.
  // "UNCLASSIFIED") would risk masking a deployment that never set it.
  classificationBannerText       String   @default("UNCONFIGURED — SET CLASSIFICATION BANNER IN ADMIN SETTINGS")
  classificationBannerBgColor    String   @default("#b71c1c")
  classificationBannerTextColor  String   @default("#ffffff")
  // SMTP (§5) — used for account-related email (password reset/set) and,
  // eventually, job completion/failure notifications (§2.2). Password is
  // AES-256-GCM encrypted at rest (same scheme as ApiKey/WebhookDestination
  // secrets) and never returned by any API response.
  smtpHost                       String?
  smtpPort                       Int?
  smtpSecure                     Boolean  @default(false)
  smtpUsername                   String?
  smtpEncryptedPassword          String?
  smtpFromAddress                String?
  // Syslog audit-event mirror (§7.1) — RFC 5424 messages, RFC 6587-style
  // framing over TCP or UDP, TLS optional (RFC 5425) rather than
  // mandatory, matching environments that already terminate transport
  // security at the network layer. Independent of the 14-day Postgres
  // audit retention below — this is a live forwarding path to an
  // external SIEM, not a second copy of local storage.
  syslogEnabled                  Boolean         @default(false)
  syslogHost                     String?
  syslogPort                     Int?
  syslogTransport                SyslogTransport @default(TCP)
  syslogTls                      Boolean         @default(false)
  // Optional PEM-encoded CA certificate(s) used to verify the syslog
  // receiver's TLS certificate. On-prem SIEMs/rsyslog commonly present a
  // certificate signed by a private CA that isn't in the system trust
  // store; without this, tls.connect() rejects the handshake. Leaving it
  // null falls back to the Node/system default trust roots. We never
  // disable verification outright — trusting an explicit CA is the safe
  // way to support private PKIs.
  syslogTlsCaCert                String?
  // Recurring admin usage-report email (§2.5/§8) — a PDF summary of
  // run counts/success-failure rates/token usage/cost, sent to these
  // recipients on the configured cadence over the same SMTP config
  // above. lastSentAt drives "is one due yet" rather than a separate
  // cron-like schedule table, since REQUIREMENTS frames this as one
  // admin-wide setting, not multiple independently-schedulable reports.
  usageReportEnabled             Boolean               @default(false)
  usageReportRecipients          String[]              @default([])
  usageReportFrequency           UsageReportFrequency  @default(WEEKLY)
  usageReportLastSentAt          DateTime?
  // Login-screen consent/warning banner (§40) — off by default (unlike
  // the classification banner above, this has no legitimate "unconfigured
  // but loud about it" state; a deployment that doesn't need one just
  // leaves it disabled). Publicly readable (GET /api/settings) since the
  // login page renders it before any authentication happens.
  consentBannerEnabled              Boolean  @default(false)
  consentBannerTitle                String   @default("")
  consentBannerBody                 String   @default("")
  // When true, the login form (SSO and local both) is hidden behind an
  // Accept/Reject gate — Accept reveals it (and is audit-logged, since
  // the app already has a full audit trail per §7.1 and "who
  // acknowledged the consent banner" is compliance-relevant); Reject
  // sends the visitor to a generic "you must accept to proceed" page
  // with no path back to the login form. When false, the banner is
  // shown alongside the form with no gating.
  consentBannerRequireAcceptReject  Boolean  @default(false)
  updatedAt                      DateTime @updatedAt

  @@map("app_settings")
}

// ---------------------------------------------------------------------------
// Audit trail (REQUIREMENTS §7.1)
// ---------------------------------------------------------------------------

enum ActorType {
  USER
  SERVICE
}

enum AuditResult {
  SUCCESS
  FAILURE
}

enum SyslogTransport {
  TCP
  UDP
}

enum UsageReportFrequency {
  WEEKLY
  MONTHLY
}

model AuditEvent {
  id            String      @id @default(uuid())
  timestamp     DateTime    @default(now())
  actorType     ActorType
  actorId       String
  actorEmail    String
  action        String // "<resource>.<operation>", e.g. "job.create"
  targetType    String
  targetId      String?
  targetName    String?
  result        AuditResult
  errorMessage  String?
  sourceIp      String?
  correlationId String?
  details       Json?

  @@index([timestamp])
  @@index([correlationId])
  @@map("audit_events")
}
