{
  "title": "AI \u2014 Savings vs Hosted Models",
  "uid": "nexus-ai-savings",
  "description": "API-bill avoidance from serving model calls locally (Ollama behind the LiteLLM gateway) instead of public hosted APIs.",
  "tags": [
    "nexus-scheduler",
    "ai",
    "finops"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
