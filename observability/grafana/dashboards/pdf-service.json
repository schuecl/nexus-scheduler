{
  "uid": "nexus-pdf",
  "title": "PDF Service \u2014 Rendering",
  "tags": [
    "nexus-scheduler",
    "app",
    "pdf"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "description": "The Chromium render path \u2014 the most memory-hungry component in the stack, and the one most likely to be OOM-killed. Runtime names verified against prom-client 15.1.3.",
  "panels": [
    {
      "type": "row",
      "title": "Renders",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Renders by result",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result, template) (rate(nexus_scheduler_pdf_renders_total[5m]))",
          "legendFormat": "{{template}} {{result}}"
        }
      ],
      "description": "nexus_scheduler_pdf_renders_total{template,result}."
    },
    {
      "type": "stat",
      "title": "Failure ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(nexus_scheduler_pdf_renders_total{result!=\"success\"}[10m])) / clamp_min(sum(rate(nexus_scheduler_pdf_renders_total[10m])), 0.0001)",
          "legendFormat": "failures"
        }
      ],
      "description": "Cross-check a spike here against OOM kills on the Infrastructure dashboard before suspecting the templates."
    },
    {
      "type": "stat",
      "title": "Renders (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(nexus_scheduler_pdf_renders_total[24h]))",
          "legendFormat": "renders"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Render duration percentiles",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(nexus_scheduler_pdf_render_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nexus_scheduler_pdf_render_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(nexus_scheduler_pdf_render_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "description": "Chromium startup dominates the low end; a rising p99 usually means memory pressure, not template complexity."
    },
    {
      "type": "timeseries",
      "title": "Duration by template (p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, template) (rate(nexus_scheduler_pdf_render_duration_seconds_bucket[5m])))",
          "legendFormat": "{{template}}"
        }
      ],
      "description": "Which template is expensive \u2014 the histogram carries a template label, so this one is answerable today."
    },
    {
      "type": "row",
      "title": "Node.js runtime \u2014 saturation signals",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      }
    },
    {
      "type": "timeseries",
      "title": "Event loop lag (p99 / mean)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_eventloop_lag_p99_seconds{service=\"pdf-service\"}",
          "legendFormat": "p99"
        },
        {
          "refId": "B",
          "expr": "nodejs_eventloop_lag_mean_seconds{service=\"pdf-service\"}",
          "legendFormat": "mean"
        }
      ],
      "description": "The single best saturation signal for a Node process: when the loop lags, everything queues behind it \u2014 requests, timers and job callbacks alike."
    },
    {
      "type": "timeseries",
      "title": "Heap used vs total",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_heap_size_used_bytes{service=\"pdf-service\"}",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "nodejs_heap_size_total_bytes{service=\"pdf-service\"}",
          "legendFormat": "total"
        },
        {
          "refId": "C",
          "expr": "process_resident_memory_bytes{service=\"pdf-service\"}",
          "legendFormat": "rss"
        }
      ],
      "description": "RSS climbing while heap stays flat points outside the JS heap \u2014 native buffers, or Chromium in the PDF path."
    },
    {
      "type": "timeseries",
      "title": "GC time",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(nodejs_gc_duration_seconds_sum{service=\"pdf-service\"}[5m]))",
          "legendFormat": "{{kind}}"
        }
      ],
      "description": "Fraction of wall-clock spent in GC, by collection kind. A rising `major` share means the heap is under real pressure, not just busy."
    },
    {
      "type": "timeseries",
      "title": "CPU",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total{service=\"pdf-service\"}[5m])",
          "legendFormat": "cores"
        }
      ],
      "description": "Node is single-threaded: sustained values near 1 core mean this process is the bottleneck."
    },
    {
      "type": "timeseries",
      "title": "Active handles",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_active_handles_total{service=\"pdf-service\"}",
          "legendFormat": "handles"
        }
      ],
      "description": "Steadily climbing handles with flat throughput is the classic leak signature (sockets or timers never released)."
    },
    {
      "type": "timeseries",
      "title": "Open file descriptors",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_open_fds{service=\"pdf-service\"}",
          "legendFormat": "open"
        },
        {
          "refId": "B",
          "expr": "process_max_fds{service=\"pdf-service\"}",
          "legendFormat": "max"
        }
      ],
      "description": "Approaching max_fds means new connections start failing."
    }
  ]
}