# Reference only. For local Compose use, run scripts/generate-local-env.sh
# from the repo root instead of copying this file — it writes this exact
# file with real random secrets, alongside the root .env.
#
# This is LibreChat's own config file (bind-mounted into the librechat
# container at /app/.env), separate from Nexus Scheduler's own .env —
# LibreChat expects dozens of settings Nexus Scheduler has no opinion on
# (auth, providers, session lifetime), so it gets its own file rather
# than polluting the root one.

DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true

# Required for LibreChat to start at all — sign/encrypt sessions and
# stored credentials (e.g. its own users' provider API keys).
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=changeme-generate-with-openssl-rand-hex-32
CREDS_KEY=changeme-generate-with-openssl-rand-hex-32
CREDS_IV=changeme-generate-with-openssl-rand-hex-16

# At least one of these is required before you can create an Agent —
# LibreChat has nothing to call otherwise. Fill in a real key, then
# `docker compose restart librechat`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
