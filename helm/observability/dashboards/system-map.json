{
  "uid": "nexus-system-map",
  "title": "System Map — Connection Health",
  "tags": [
    "nexus-scheduler",
    "app",
    "architecture"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "description": "The stack as a flow chart, colored by live health metrics (native Canvas panel — no plugins, airgap-safe). Green = up, red = down, grey = no data (component absent or not scraped). Companion to the in-app Architecture page (#131), which probes application-level links; this one is the scrape-plane view.",
  "panels": [
    {
      "type": "canvas",
      "title": "Components & connections",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "ABSENT",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#9e9e9e",
                "value": null
              },
              {
                "color": "#c62828",
                "value": 0
              },
              {
                "color": "#2e7d32",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "#c62828",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "#2e7d32",
                  "index": 1
                }
              }
            }
          ]
        },
        "overrides": []
      },
