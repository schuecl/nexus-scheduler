    {
      "type": "stat",
      "title": "Component health",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "ABSENT",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#9e9e9e",
                "value": null
              },
              {
                "color": "#c62828",
                "value": 0
              },
              {
                "color": "#2e7d32",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "#c62828",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "#2e7d32",
                  "index": 1
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{service=\"api\"})",
          "instant": true,
          "legendFormat": "api"
        },
        {
          "refId": "B",
          "expr": "max(up{service=\"worker\"})",
          "instant": true,
          "legendFormat": "worker"
        },
        {
          "refId": "C",
          "expr": "max(up{service=\"pdf-service\"})",
          "instant": true,
          "legendFormat": "pdf-service"
        },
        {
          "refId": "D",
          "expr": "max(up{service=\"ocr\"})",
          "instant": true,
          "legendFormat": "ocr"
        },
        {
          "refId": "E",
          "expr": "max(litellm_gateway_up)",
          "instant": true,
          "legendFormat": "gateway"
        },
        {
          "refId": "F",
          "expr": "max(pg_up)",
          "instant": true,
          "legendFormat": "postgres"
        },
        {
          "refId": "G",
          "expr": "max(redis_up)",
          "instant": true,
          "legendFormat": "redis"
        },
        {
          "refId": "H",
          "expr": "clamp_max(count(container_memory_working_set_bytes{name=~\".*librechat-1.*\"}), 1)",
          "instant": true,
          "legendFormat": "librechat"
        },
        {
          "refId": "J",
          "expr": "clamp_max(count(container_memory_working_set_bytes{name=~\".*librechat-mongo.*\"}), 1)",
          "instant": true,
          "legendFormat": "mongo"
        },
        {
          "refId": "I",
          "expr": "clamp_max(count(container_memory_working_set_bytes{name=~\".*ollama-1.*\"}), 1)",
          "instant": true,
          "legendFormat": "ollama"
        }
      ],
      "description": "One stat per component — the row an alert rule would key on. UP/DOWN from health metrics; ABSENT means the component exposes no metric here (not deployed, or not scraped). LibreChat/Mongo/Ollama expose no /metrics, so their signal is container presence (docker-desktop profile's container-stats-exporter)."
    }
